# Copy this file to .env.development (for `expo start`) and .env.production (for `expo export`).
# All EXPO_PUBLIC_* values are bundled into the client build — do not put secrets here.

# Backend API base URL. The app appends /api/v1/<endpoint>.
# Dev: point at the Caddy proxy (https://localhost:8443) to bypass CORS via shared origin.
# Prod: the real backend host — no proxy.
EXPO_PUBLIC_API_URL=
