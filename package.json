{
  "name": "iris-eSIM",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "web": "BROWSER=none expo start --web",
    "proxy": "caddy run",
    "dev": "concurrently --kill-others-on-fail -n expo,proxy,open -c blue,magenta,green \"pnpm web\" \"pnpm proxy\" \"wait-on -t 60000 tcp:8081 tcp:8443 && open https://localhost:8443\"",
    "predeploy": "expo export -p web",
    "deploy": "netlify deploy --dir dist",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^54.0.0",
    "expo-checkbox": "~5.0.8",
    "expo-constants": "~18.0.13",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.8.17",
    "lodash": "^4.17.23",
    "lucide-react": "^1.16.0",
    "mkcert": "^3.2.0",
    "nativewind": "latest",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^16.5.6",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^55.0.10",
    "concurrently": "^9.1.0",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.1"
  },
  "main": "expo-router/entry",
  "private": true
}
